---
layout: base.njk
bgclass: bg-2
title: Bærum Salongorkester – Events
description: Konserter og andre events med Bærum Salongorkester
---
<div class="centered">
  <h1>
    Konserter og andre arrangementer
  </h1>
  {% for event in events %}
    <div class="event">
      <div class="event-title">
        <h3>
          {{ event.title }}
        </h3>
      </div>
      <div class="event-body">
        {{ event.body | safe }}
      </div>
      <div class="event-details">
        {% if event.open %}
        <div>
          <div>
            Dørene åpner
          </div>
          <div>
            {{ event.open }}
          </div>
        </div>
        {% endif %}
        {% if event.start %}
          <div>
            <div>
              Start
            </div>
            <div>
              {{ event.start }}
            </div>
          </div>
        {% endif %}
        {% if event.end %}
          <div>
          <div>
            Slutt
          </div>
          <div>
            {{ event.end }}
          </div>
          </div>
        {% endif %}
        {% if event.tickets %}
          <div>
          <div>
            Billetter
          </div>
          <div>
            <a href="{{ event.tickets }}">{{ event.tickets }}</a>
          </div>
          </div>
        {% endif %}
        {% if event.facebook %}
          <div>
            <div>
              Facebook
            </div>
            <div>
              <a class="social" href="{{ event.facebook }}" target="_blank" rel="noopener" aria-label="{{ event.title }}">
                <img src="/assets/facebook.svg" alt="">
              </a>
            </div>
          </div>
        {% endif %}
        {% if event.map or event.place %}
          <div>
            <div>
              Sted
            </div>
            <div>
              {{ event.place }}
              {% if event.map %}
                <a href="{{ event.map }}"><img class="icon" src="/assets/location.svg" /></a>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% if event.embed %}
          <div class="centered map-embed">
            <iframe src="{{ event.embed }}" allowfullscreen="true" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
  <script type="text/javascript" src="/text.js"></script>
  <script type="text/javascript">
   adjustTitles("event-title", "--pico-font-size");
  </script>
</div>
